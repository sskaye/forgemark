{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forgemark",
  "version": "1.3.0",
  "identifier": "com.forgemark.app",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Forgemark — Untitled",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Forgemark contributors",
    "copyright": "© 2026 Forgemark contributors",
    "category": "Productivity",
    "shortDescription": "Collaborative review of markdown documents.",
    "longDescription": "Forgemark is a desktop app for collaborative review of markdown documents — by humans and AI agents working as peers. Comments, threaded replies, and suggested edits live inside the .md file itself.",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown document",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": []
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    }
  }
}
